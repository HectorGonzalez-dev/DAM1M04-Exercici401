<main>
    <h1 class="page-title">Productos</h1>
    <div style="margin-bottom: 1.5em;">
        <a href="/productAdd" class="main-btn add-btn" style="float:right;">+ Nuevo producto</a>
        <div style="clear:both;"></div>
    </div>
        <form id="searchForm" action="/products" method="GET">
            <div class="search-bar-div">
                <button type="submit" form="searchForm" class="search-button">🔍</button>
                <input type="hidden" name="page" value="1">
                <input class="search-bar" type="text" name="search" placeholder="  Buscar..."/>
                <a class="cancel-search" href="/products?page=1">X</a>
            </div>
        </form>
    <div class="container big-table-div">
        <table class="big-table">

            <thead>
                <tr>
                    <th style="text-align: left;">Producto</th>
                    <th style="text-align: left;">Categoría</th>
                    <th style="text-align: left;">Precio</th>
                    <th style="text-align: center;">Stock</th>
                    <th style="text-align: center;">Activo</th>
                    <th style="text-align: center;">Acciones</th>
                </tr>
            </thead>
            {{#each page_products}}
                <tr>
                    <td>{{name}}</td>
                    <td>{{category}}</td>
                    <td>€ {{price}}</td>
                    <td class="centered-cell
                        {{#if (gt stock 25)}}ok-stock
                        {{else if (gt stock 10)}}low-stock
                        {{else}}critic-stock{{/if}}">
                        {{stock}}
                    </td>
                    <td class="centered-cell">{{#if (eq active 1)}}Activo{{else}}Inactivo{{/if}}</td>
                    <td class="centered-cell">Editar</td>
                </tr>
            {{/each}}
        </table>
    </div>
    <div class="page-nav-container">
        <div class="page-nav">
            <a {{#unless (eq page_num 1)}}
                href="/products?page={{prev_page}}{{#if search_string}}&search={{search_string}}{{/if}}"
                {{/unless}}
                class="page-arrow {{#if (eq page_num 1)}}inactive-arrow{{/if}}">
            &lt;
            </a>
            <p class="page-number">Página {{page_num}}</p>
            <a {{#unless (eq page_num total_pages)}}
                href="/products?page={{next_page}}{{#if search_string}}&search={{search_string}}{{/if}}"
                {{/unless}}
                class="page-arrow {{#if (eq page_num total_pages)}}inactive-arrow{{/if}}">
            &gt;
            </a>
        </div>
    </div>
</main>