<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        {{> header}}
        <title>Clientes</title>
    </head>
    <body>
        {{> menu}}
        <main class="container customers-section">
            <h2>First 25 Customers - First 5 Rentals</h2>
            <div class="customer-list">
                <!-- Customer Card -->
                {{#each customer}}
                <div class="customer-card">
                    <div class="customer-header">
                        <h3>{{first_name}} {{last_name}}</h3>
                        <p class="customer-email">{{email}}</p>
                        <p class="customer-id">Customer ID: {{customer_id}}</p>
                    </div>

                    <div class="rentals">
                        <h4>First 5 Rentals</h4>

                        <ul class="rental-list">
                            {{#each rentals}}
                            <li class="rental-item">
                                <div class="rental-info">
                                    <p class="rental-title">{{title}}</p>
                                    <p>Rental Date: {{rental_date}}</p>
                                    <p>Return Date: {{return_date}}</p>
                                </div>
                            </li>
                            {{/each}}
                        </ul>
                    </div>
                </div>
                {{/each}}
            </div>
        </main>
        {{> footer}}
    </body>
</html>
