<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        {{> header}}
        <title>Editor</title>
    </head>
    <body>
        {{> menu}}
        <main class="container">
            <div class="movie-detail">

                <!-- Header -->
                <div class="movie-detail-header">
                    <h1>Editar película</h1>
                </div>

                <!-- Contenido principal -->
                <form id="editForm" class="movie-detail-body" method="POST" action="/editarPeli">

                    <input type="hidden" name="table" value="film">
                    <input type="hidden" name="id" value="{{movie.film_id}}">

                    <!-- Cover -->
                    <div class="movie-cover-wrapper">
                        <img class="movie-cover-large" src="/img/cover_placeholder.png" alt="{{movie.title}}"/>
                    </div>

                    <!-- Info -->
                    <div class="movie-info-block">

                        <!-- Título -->
                        <div>
                            <label><strong>Título</strong></label>
                            <input type="text" name="title" value="{{movie.title}}" class="input-field" required pattern=".*\S.*" maxlength="128" oninvalid="this.classList.add('error')" oninput="this.classList.remove('error')"/>
                        </div>

                        <!-- Descripción -->
                        <div>
                            <label><strong>Descripción</strong></label>
                            <textarea name="description" class="input-field" rows="5" required oninvalid="this.classList.add('error')" oninput="this.classList.remove('error')">{{movie.description}}</textarea>
                        </div>

                        <!-- Metadata -->
                        <div class="movie-meta">

                            <p>
                                <strong>Año:</strong>
                                <input type="number" name="release_year" value="{{movie.release_year}}" class="input-field small" required min="1888" oninvalid="this.classList.add('error')" oninput="this.classList.remove('error')"/>
                            </p>

                            <p>
                                <strong>Idioma:</strong>
                                <select name="language" class="input-field small" required>
                                    {{#each language}}
                                        <option value="{{language_id}}" {{#if (eq ../movie.language_id language_id)}}selected{{/if}}>{{name}}</option>
                                    {{/each}}
                                </select>
                            </p>

                            <p>
                                <strong>Duración:</strong>
                                <input type="number" name="length" value="{{movie.length}}" class="input-field small" required min="1" oninvalid="this.classList.add('error')" oninput="this.classList.remove('error')"/> min
                            </p>

                            <p>
                                <strong>Rating:</strong>
                                <select name="rating" class="input-field small" required>
                                    <option value="G" {{#if (eq movie.rating "G")}}selected{{/if}}>G</option>
                                    <option value="PG" {{#if (eq movie.rating "PG")}}selected{{/if}}>PG</option>
                                    <option value="PG-13" {{#if (eq movie.rating "PG-13")}}selected{{/if}}>PG-13</option>
                                    <option value="R" {{#if (eq movie.rating "R")}}selected{{/if}}>R</option>
                                    <option value="NC-17" {{#if (eq movie.rating "NC-17")}}selected{{/if}}>NC-17</option>
                                </select>
                            </p>

                        </div>

                        <!-- Actores -->
                        <div class="movie-actors">
                            <h3>Actores</h3>

                            <div class="actors-list">
                                {{#each movie.actors}}
                                    <span class="actor">
                                        {{first_name}} {{last_name}}
                                    </span>
                                {{/each}}
                            </div>
                        </div>

                    </div>
                </form>

                <!-- Botones -->
                <div class="movie-form-actions">
                    <a href="/movie?id={{movie.film_id}}" class="btn-cancel">Cancelar</a>


                    <form method="POST" action="/esborrarPeli">
                        <input type="hidden" name="table" value="film">
                        <input type="hidden" name="id" value="{{movie.film_id}}">
                        <button type="submit" class="btn-delete">
                            Borrar
                        </button>
                    </form>

                    <button type="submit" form="editForm" class="btn-save">
                        Guardar cambios
                    </button>
                </div>

            </div>
        </main>
        {{> footer}}
    </body>
</html>
